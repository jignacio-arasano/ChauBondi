# ─── Supabase ────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── JWT ─────────────────────────────────────────────
# Generá uno seguro: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=tu_jwt_secret_super_seguro_de_64_chars_minimo

# ─── MercadoPago ─────────────────────────────────────
# Producción: APP_USR-...
# Sandbox: TEST-...
MP_ACCESS_TOKEN=TEST-xxxxxxxxxxxxxxxxxxxx

# ─── URLs ────────────────────────────────────────────
# En Railway, estos serán los dominios de tu servicio
FRONTEND_URL=https://chaubondi.up.railway.app
BACKEND_URL=https://chaubondi.up.railway.app

# ─── Puerto ──────────────────────────────────────────
PORT=3001

# ─── Entorno ─────────────────────────────────────────
NODE_ENV=production
